# Voice assistant service
LUNACANE_VOICE_HOST=0.0.0.0
LUNACANE_VOICE_PORT=8000

# LLM compatible with OpenAI Chat Completions, for example DashScope compatible mode
LUNACANE_LLM_API_KEY=replace_me
LUNACANE_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LUNACANE_LLM_MODEL=qwen-plus

# Aliyun NLS ASR
LUNACANE_ALIYUN_NLS_APP_KEY=replace_me
LUNACANE_ALIYUN_AK_ID=replace_me
LUNACANE_ALIYUN_AK_SECRET=replace_me

# Optional. Leave empty if ffmpeg is already in PATH.
LUNACANE_FFMPEG_PATH=

# Debug data server
LUNACANE_DEBUG_MAX_SAMPLES=3000
